

@page "/"
@using QueueCumber.Core
@using QueueCumber.WebApp.Components.Views.Configuration
@using QueueCumber.WebApp.Components.Views.Connection

<MudDynamicTabs @ref="@DynamicTabs" @bind-ActivePanelIndex="@UserIndex"
                AddTab="@AddTabCallback" CloseTab="@CloseTabCallback"
                AddIconToolTip="Click to add a new tab" CloseIconToolTip="Close tab. All data will be lost"
                PanelClass="px-4 py-6" Elevation="4" Rounded ApplyEffectsToContainer>
    @foreach (var instance in _instances)
    {
        <MudTabPanel ID="@instance.Connection.Id" Text="@instance.Connection.Name" ShowCloseIcon="true"><ConnectionView  _instance="instance" /></MudTabPanel>
    }
    <MudTabPanel Text="Connections" ShowCloseIcon="false"><ConfigurationView onConnected="LoadTabs" /></MudTabPanel>
</MudDynamicTabs>

@code {


    [Inject]
    private IQueueCumberService _queueCumberService { get; set; } 


    private List<ConnectionIntance> _instances { get; set; } = new List<ConnectionIntance>();



    public MudDynamicTabs DynamicTabs;
    public int UserIndex;
    bool _stateHasChanged;


    void RestoreUserTabs()
    {

        UserIndex = 1; // Start on 2nd tab: "Tab B"
        _stateHasChanged = true;
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        LoadTabs();
    }

    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);
        if (_stateHasChanged)
        {
            _stateHasChanged = false;
            StateHasChanged();
        }
    }

    public void LoadTabs()
    {
        _instances = _queueCumberService.Instances();
        _stateHasChanged = true;
        
    }

    public void AddTab(Guid id)
    {
        
        _stateHasChanged = true;
    }

    public void RemoveTab(Guid id)
    {
        _stateHasChanged = true;
    }

    void AddTabCallback() => AddTab(Guid.NewGuid());
    void CloseTabCallback(MudTabPanel panel) => RemoveTab((Guid)panel.ID);
}